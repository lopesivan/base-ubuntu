#!/usr/bin/with-contenv bash
# cont-init.d/10-adduser
set -euo pipefail

cat <<'BANNER'
-------------------------------------
            ██╗  ██╗██████╗
            ██║  ██║╚════██╗
            ███████║ █████╔╝
            ╚════██║██╔═══╝
                 ██║███████╗
                 ╚═╝╚══════╝
                       Algoritmos

Author: Ivan Lopes
  Mail: lopesivan.ufrj@gmail.com
  Site: ivanlopes.eng.br
-------------------------------------
BANNER

log() { echo "[adduser] $*"; }

# PUID/PGID são as variáveis seguras — UID/GID são readonly no bash
_USER="${USER:-}"
_GROUP="${GROUP:-}"
_UID="${PUID:-}"
_GID="${PGID:-}"

log "USER=${_USER} GROUP=${_GROUP} UID=${_UID} GID=${_GID}"

if [[ -z "$_GID" || -z "$_UID" || -z "$_USER" || -z "$_GROUP" ]]; then
  log "Sem variáveis de usuário — mantendo root"
  exit 0
fi

# --- Grupo ------------------------------------------------------------------
if getent group "$_GID" >/dev/null 2>&1; then
  log "GID $_GID já existe"
elif getent group "$_GROUP" >/dev/null 2>&1; then
  log "Grupo $_GROUP já existe"
else
  log "Criando grupo $_GROUP (GID=$_GID)"
  groupadd -g "$_GID" "$_GROUP"
fi

# --- Usuário ----------------------------------------------------------------
if getent passwd "$_UID" >/dev/null 2>&1; then
  log "UID $_UID já existe"
elif getent passwd "$_USER" >/dev/null 2>&1; then
  log "Usuário $_USER já existe"
else
  log "Criando usuário $_USER (UID=$_UID GID=$_GID)"
  useradd -u "$_UID" -g "$_GID" -M -s /bin/bash "$_USER"
fi

export HOME="/home/$_USER"
mkdir -p "$HOME"
chown "$_USER:$_GROUP" "$HOME"
log "HOME=$HOME pronto"
