#!/bin/bash
ENV_DIR="/var/run/s6/container_environment"

if [[ -d "$ENV_DIR" ]]; then
  for f in "$ENV_DIR"/*; do
    [[ -f "$f" ]] || continue
    varname="$(basename "$f")"
    [[ "$varname" == "UID" || "$varname" == "GID" ]] && continue
    export "$varname"="$(cat "$f")"
  done
fi

[[ -f "$ENV_DIR/UMASK" ]] && umask "$(cat "$ENV_DIR/UMASK")"

exec "$@"
