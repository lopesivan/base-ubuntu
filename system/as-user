#!/bin/bash
# as-user — cria grupo/usuário e troca para ele via su-exec
set -euo pipefail

log() { echo "[as-user] $*"; }

_USER="${USER:-}"
_GROUP="${GROUP:-}"
_USER_ID="${PUID:-${UID:-}}"
_GROUP_ID="${PGID:-${GID:-}}"

log "USER=${_USER} GROUP=${_GROUP} UID=${_USER_ID} GID=${_GROUP_ID}"

if [[ -z "$_GROUP_ID" || -z "$_USER_ID" || -z "$_USER" || -z "$_GROUP" ]]; then
    log "Rodando como root"
    exec "$@"
fi

if getent group "$_GROUP_ID" >/dev/null 2>&1; then
    log "GID $_GROUP_ID já existe"
elif getent group "$_GROUP" >/dev/null 2>&1; then
    log "Grupo $_GROUP já existe com GID diferente"
else
    log "Criando grupo $_GROUP com GID $_GROUP_ID"
    groupadd -g "$_GROUP_ID" "$_GROUP"
fi

if getent passwd "$_USER_ID" >/dev/null 2>&1; then
    log "UID $_USER_ID já existe"
elif getent passwd "$_USER" >/dev/null 2>&1; then
    log "Usuário $_USER já existe com UID diferente"
else
    log "Criando usuário $_USER UID=$_USER_ID GID=$_GROUP_ID"
    useradd -u "$_USER_ID" -g "$_GROUP_ID" -M -s /bin/bash "$_USER"
fi

export HOME="/home/$_USER"
mkdir -p "$HOME"
chown "$_USER:$_GROUP" "$HOME"

log "Executando como $_USER: $*"
exec /usr/local/bin/su-exec "$_USER" "$@"
