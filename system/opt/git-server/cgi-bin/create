#!/usr/bin/env bash
set -Eeuo pipefail

echo "Content-Type: text/plain"
echo

repo="${QUERY_STRING#repo=}"
repo="${repo%.git}.git"

case "$repo" in
    ""|".git"|*/*|*..*) echo "invalid repo"; exit 1 ;;
esac

path="/srv/git/$repo"

if [ -d "$path" ]; then
    echo "exists: $repo"
    exit 0
fi

git init --bare "$path"
touch "$path/git-daemon-export-ok"
git --git-dir="$path" config daemon.receivepack true
git --git-dir="$path" symbolic-ref HEAD refs/heads/main

echo "created: $repo"
echo "url: git://$SERVER_NAME:9418/$repo"
